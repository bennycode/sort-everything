{
  "activationEvents": ["onCommand:bennycode.sort-everything.sortFile"],
  "author": "Benny Neugebauer",
  "categories": ["Other"],
  "contributes": {
    "commands": [
      {
        "command": "bennycode.sort-everything.sortFile",
        "title": "Sort Everything"
      }
    ],
    "keybindings": [
      {
        "command": "bennycode.sort-everything.sortFile",
        "key": "alt+shift+l",
        "when": "editorTextFocus"
      }
    ]
  },
  "dependencies": {
    "@types/jsonabc": "^2.3.1",
    "json5": "^2.2.3",
    "jsonabc": "^2.3.1",
    "yaml": "^2.8.3"
  },
  "description": "Sort JSON, YAML and plain text files by using a keyboard shortcut.",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/vscode": "^1.68.0",
    "@vscode/test-electron": "^2.3.0",
    "cross-env": "^7.0.3",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.0.1"
  },
  "displayName": "Sort Everything",
  "engines": {
    "vscode": "^1.68.0"
  },
  "galleryBanner": {
    "color": "#1739EE",
    "theme": "dark"
  },
  "homepage": "https://github.com/bennycode/sort-everything",
  "icon": "assets/icon.png",
  "keywords": ["sorting", "sort", "yaml", "yml", "plaintext", "text", "json", "lines", "code"],
  "license": "MIT",
  "main": "./dist/extension.js",
  "name": "sort-everything",
  "publisher": "bennycode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bennycode/sort-everything.git"
  },
  "scripts": {
    "compile": "webpack",
    "fix": "biome check --write",
    "lint": "biome check",
    "package": "webpack --mode production --devtool hidden-source-map",
    "postversion": "git push origin main && git push origin --tags",
    "pretest": "yarn run compile && yarn run lint",
    "test": "tsc --noEmit && yarn test:unit",
    "test:unit": "cross-env NODE_ENV=test jest ./src --passWithNoTests",
    "vscode:prepublish": "yarn run package",
    "watch": "webpack --watch"
  },
  "version": "1.4.2"
}
