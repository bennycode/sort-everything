exports[`sortYAML sorts lists with special characters in key values 1`] = `
"# Test case: Empty values and special characters
items:
  - key: 'a-normal'
    value: 'test'
  - key: 'm-number'
    value: 123
  - key: 'z-special'
    value: ''
"
`;

exports[`sortYAML sorts nested lists with "key" fields 1`] = `
"# Test case: Nested lists where child lists have "key" fields
# The inner lists should be sorted by key
envVars:
  development:
    - key: BETA_VAR
      value: 'b'
    - key: YELLOW_VAR
      value: 'y'
  production:
    - key: APPLE_VAR
      value: 'a'
    - key: ZEBRA_VAR
      value: 'z'
"
`;

exports[`sortYAML sorts nested sequences by their leading element key 1`] = `
"# Test: Nested sequences (list of lists) where each inner sequence has maps with "key" fields
# The outer list should be sorted by the first element's "key" value of each inner list
groups:
  - - key: APPLE_1
      value: 'a1'
    - key: APPLE_2
      value: 'a2'
  - - key: MIDDLE_1
      value: 'm1'
    - key: MIDDLE_2
      value: 'm2'
  - - key: ZEBRA_1
      value: 'z1'
    - key: ZEBRA_2
      value: 'z2'
"
`;
